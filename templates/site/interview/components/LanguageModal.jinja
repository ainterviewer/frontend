{#def project_id: str, languages: list[dict[str, str]] #}
<div id="language-modal" class="modal" style="display: block">
    <div class="modal-content">
        <h2>Select language</h2>
        <div class="language-options">
            {% for lang in languages %}
                <button class="language-button"
                        hx-post="/api/projects/{{ project_id }}/consent/render"
                        data-lang="{{ lang.code }}"
                        hx-target="#language-modal"
                        hx-swap="outerHTML">{{ lang.name }}</button>
            {% endfor %}
        </div>
    </div>
</div>
<script>
    document.body.addEventListener("click", function (e) {
        if (e.target.classList.contains("language-button")) {
            const langCode = e.target.dataset.lang;
            document.cookie = `language=${langCode}; path=/`;
        }
    });
</script>
